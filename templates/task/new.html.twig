{% extends 'base.html.twig' %}
{% block title %}Nouvelle Tâche{% endblock %}
{% block body %}
<div class="min-h-screen bg-blue-300 bg-opacity-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-md p-8 w-full max-w-md relative">

        <button class="absolute top-4 right-4 text-gray-400 hover:text-gray-600">✕</button>

        <h1 class="text-xl font-bold text-gray-800 mb-1">Créer une tâche</h1>
        <p class="text-gray-400 text-sm mb-6">Ajoutez une nouvelle tâche à votre liste</p>

        {{ form_start(form) }}

            <div class="mb-4">
                <label class="block text-sm text-gray-700 mb-1">Titre de la tâche</label>
                {{ form_widget(form.Title, {
                    'attr': {'class': 'w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300', 'placeholder': 'Ex: Faire les courses'}
                }) }}
            </div>

            <div class="mb-4">
                <label class="block text-sm text-gray-700 mb-1">Priorité</label>
                {{ form_widget(form.Priority, {
                    'attr': {'class': 'w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300'}
                }) }}
            </div>

            <div class="mb-6">
                <label class="block text-sm text-gray-700 mb-1">Dossier (optionnel)</label>
                {{ form_widget(form.Folder, {
                    'attr': {'class': 'w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300'}
                }) }}
            </div>

            <div class="flex justify-end gap-3">
                <a href="{{ path('app_task_index') }}" class="px-4 py-2 text-sm text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-100">
                    Annuler
                </a>
                <button type="submit" class="px-4 py-2 text-sm bg-gray-800 text-white rounded-lg hover:bg-gray-700">
                    Créer
                </button>
            </div>

        {{ form_end(form) }}

    </div>
</div>
{% endblock %}