{% extends 'base.html.twig' %}
{% block title %}Login!{% endblock %}
{% block body %}
<div class="min-h-screen bg-blue-300 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-md p-8 w-full max-w-md">

        <h1 class="text-2xl font-bold text-gray-800 mb-1">Gestion de Tâches</h1>
        <p class="text-gray-400 text-sm mb-6">Organisez votre journée efficacement</p>

        <div class="flex rounded-lg overflow-hidden border border-gray-200 mb-6">
            <a href="/login" class="w-1/2 text-center py-2 bg-white font-semibold text-gray-800 border-r border-gray-200">Connexion</a>
            <a href="/register" class="w-1/2 text-center py-2 text-gray-500 hover:bg-gray-100">Inscription</a>
        </div>

        {% if error %}
            <div class="bg-red-100 text-red-600 text-sm rounded-lg px-4 py-2 mb-4">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
        {% endif %}

<form method="post">
<label for="username">Email</label>
<input type="email" value="{{ last_username }}" name="_username" id="username" class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" placeholder="votre@email.com" autocomplete="email" required autofocus>
<label for="password">Mot de passe</label>
<input type="password" name="_password" id="password" class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" autocomplete="current-password" required>
<input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
<button class="w-full bg-gray-800 text-white py-3 rounded-lg text-sm font-semibold hover:bg-gray-700 mt-6" type="submit">Se connecter</button>
</form>

    </div>
</div>
{% endblock %}