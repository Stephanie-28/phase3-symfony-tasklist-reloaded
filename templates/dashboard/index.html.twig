{% extends 'base.html.twig' %}
{% block body %}

{# LAYOUT PRINCIPAL #}
<div class="flex h-screen bg-blue-300">

    {# SIDEBAR #}
    <div class="w-64 bg-white border-r border-gray-200 p-4">
        <div class="font-bold mb-4">🏠 Toutes les tâches</div>
        <p class="text-xs text-gray-400 mb-2">DOSSIERS</p>
        {% for folder in folders %}
        <div class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-100">
            <span class="w-3 h-3 bg-green-500 rounded-sm"></span>
            <span>{{ folder.name }}</span>
        </div>
        {% endfor %}
    </div>

    {# CONTENU PRINCIPAL #}
    <div class="flex-1 flex flex-col">

        {# HEADER #}
        <div class="flex justify-between items-center p-6 bg-white border-b border-gray-200">
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Gestion de Tâches</h1>
                <p class="text-gray-400 text-sm">Organisez votre journée efficacement</p>
            </div>
            <div class="flex gap-3">
                <a href="#" class="flex items-center gap-1 text-sm text-gray-600 hover:text-gray-800">⚙️ Gérer les priorités</a>
                <a href="#" class="flex items-center gap-1 text-sm text-gray-600 hover:text-gray-800">📁 Nouveau dossier</a>
                <a href="{{ path('app_task_new') }}" class="flex items-center gap-2 bg-gray-800 text-white px-4 py-2 rounded-lg text-sm">+ Nouvelle tâche</a>
                <a href="{{ logout_path() }}" class="flex items-center gap-1 text-sm text-gray-600 hover:text-gray-800">↪️ Déconnexion</a>
            </div>
        </div>

        {# FILTRES #}
        <div class="flex gap-4 px-6 py-3 bg-white border-b border-gray-200">
            <span class="text-sm text-gray-500">🔽 Filtres :</span>
            <select class="text-sm border border-gray-200 rounded-lg px-3 py-1">
                <option>Tous</option>
                <option>En cours</option>
                <option>Terminé</option>
            </select>
            <select class="text-sm border border-gray-200 rounded-lg px-3 py-1">
                <option>Toutes</option>
                <option>Urgent</option>
                <option>Important</option>
                <option>Normal</option>
            </select>
        </div>

        {# LISTE DES TÂCHES #}
        <div class="flex-1 overflow-y-auto p-6 space-y-3">
            {% for task in tasks %}
            <div class="flex items-center justify-between bg-white rounded-xl p-4 shadow-sm">
                <div class="flex items-center gap-3">
                    <input type="checkbox" class="w-4 h-4 rounded-full border-gray-300">
                    <div>
                        <span class="font-medium text-gray-800">{{ task.title }}</span>
                        <span class="ml-2 text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-600">
                            {{ task.priority.name }}
                        </span>
                        <p class="text-xs text-gray-400 mt-1">{{ task.status }}</p>
                    </div>
                </div>
                <button class="text-gray-300 hover:text-yellow-400">☆</button>
            </div>
            {% endfor %}
        </div>

    </div>
</div>

{% endblock %}